function renderFlowchart(steps, color, lightBg) {
  const cs = `style="--fc-color:${color};--fc-bg:${lightBg}"`;
  let html = '';
  steps.forEach((step, i) => {
    if (i > 0) {
      html += `<div class="fc-connector"><div class="fc-line"></div><div class="fc-arrowhead"></div></div>`;
    }
    if (step.type === 'trigger') {
      html += `<div class="fc-step fc-trigger" ${cs}>${step.text}</div>`;
    } else if (step.type === 'action') {
      html += `<div class="fc-step fc-action" ${cs}>${step.text}</div>`;
    } else if (step.type === 'wait') {
      html += `<div class="fc-step fc-wait" ${cs}>${step.text}</div>`;
    } else if (step.type === 'decision') {
      html += `<div class="fc-step fc-decision" ${cs}>${step.text}</div>`;
      html += `<div class="fc-connector"><div class="fc-line"></div><div class="fc-arrowhead"></div></div>`;
      html += `<div class="fc-branches">`;
      html += `<div class="fc-branch fc-branch-yes"><div class="fc-branch-label">If yes</div>${step.yes}</div>`;
      html += `<div class="fc-branch fc-branch-no"><div class="fc-branch-label">If no</div>${step.no}</div>`;
      html += `</div>`;
    } else if (step.type === 'result') {
      html += `<div class="fc-step fc-result" ${cs}>${step.text}</div>`;
    }
  });
  return html;
}

function openDetail(id) {
