<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Automation Use Cases | Groundwork AI</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@500;700;800&family=DM+Sans:opsz,wght@9..40,400;9..40,500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #F5F2ED;
    --surface: #FFFFFF;
    --ink: #1C1A16;
    --ink-muted: #6B6860;
    --ink-faint: #A8A59F;
    --green: #2A6044;
    --green-light: #EAF3EE;
    --green-border: #9ECFB8;
    --border: #E2DED7;
    --radius: 14px;
  }

  body { font-family: 'DM Sans', system-ui, sans-serif; background: var(--bg); color: var(--ink); min-height: 100vh; font-size: 15px; line-height: 1.6; }

  /* ── HEADER ── */
  header { background: var(--ink); padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; height: 60px; position: sticky; top: 0; z-index: 200; }
  .logo { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 17px; color: #fff; letter-spacing: -0.02em; display: flex; align-items: center; gap: 8px; cursor: pointer; }
  .logo-mark { width: 24px; height: 24px; background: var(--green); border-radius: 6px; display: flex; align-items: center; justify-content: center; }
  .logo-mark svg { width: 14px; height: 14px; }
  .header-cta { font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; color: var(--ink); background: #fff; border: none; border-radius: 8px; padding: 7px 16px; cursor: pointer; text-decoration: none; transition: background .15s; }
  .header-cta:hover { background: #F0EDEA; }

  /* ── HERO ── */
  .hero { background: var(--ink); padding: 72px 2rem 80px; text-align: center; }
  .hero-eyebrow { display: inline-block; font-size: 12px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: #7FCFAA; background: rgba(42,96,68,.2); border: 1px solid rgba(42,96,68,.35); border-radius: 20px; padding: 4px 14px; margin-bottom: 24px; }
  .hero h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(36px,5vw,56px); color: #fff; line-height: 1.05; letter-spacing: -.03em; max-width: 700px; margin: 0 auto 20px; }
  .hero h1 em { font-style: normal; color: #7FCFAA; }
  .hero p { font-size: 17px; color: #A8A59F; max-width: 520px; margin: 0 auto; line-height: 1.6; }

  /* ── STATS BAR ── */
  .stats-bar { background: var(--green); padding: 16px 2rem; display: flex; justify-content: center; gap: clamp(24px,5vw,80px); flex-wrap: wrap; }
  .stat { text-align: center; }
  .stat-num { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 22px; color: #fff; display: block; }
  .stat-label { font-size: 12px; font-weight: 500; color: rgba(255,255,255,.65); }

  /* ── MAIN ── */
  main { max-width: 1160px; margin: 0 auto; padding: 48px 2rem 80px; }

  /* ── FILTERS ── */
  .filter-bar { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 36px; }
  .filter-label { font-size: 12px; font-weight: 500; letter-spacing: .06em; text-transform: uppercase; color: var(--ink-faint); margin-right: 4px; }
  .filter-btn { font-family: 'DM Sans', sans-serif; font-size: 13px; font-weight: 500; color: var(--ink-muted); background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 6px 16px; cursor: pointer; transition: all .15s; }
  .filter-btn:hover { border-color: var(--green-border); color: var(--ink); }
  .filter-btn.active { background: var(--ink); color: #fff; border-color: var(--ink); }

  /* ── CARD GRID ── */
  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 20px; }

  /* ── CARD ── */
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; display: flex; flex-direction: column; gap: 16px; cursor: pointer; transition: transform .18s, box-shadow .18s, border-color .18s; position: relative; overflow: hidden; animation: fadeUp .4s ease both; }
  .card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--card-accent, transparent); border-radius: var(--radius) var(--radius) 0 0; opacity: 0; transition: opacity .18s; }
  .card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(28,26,22,.08); border-color: var(--card-accent, var(--border)); }
  .card:hover::before { opacity: 1; }
  .card:nth-child(1){animation-delay:.05s} .card:nth-child(2){animation-delay:.1s} .card:nth-child(3){animation-delay:.15s} .card:nth-child(4){animation-delay:.2s} .card:nth-child(5){animation-delay:.25s} .card:nth-child(6){animation-delay:.3s} .card:nth-child(7){animation-delay:.35s} .card:nth-child(8){animation-delay:.4s} .card:nth-child(9){animation-delay:.45s}

  .card-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .card-icon svg { width: 22px; height: 22px; }
  .card-header { display: flex; align-items: flex-start; gap: 14px; }
  .card-titles { flex: 1; }
  .card-category { font-size: 11px; font-weight: 500; letter-spacing: .07em; text-transform: uppercase; margin-bottom: 4px; }
  .card h3 { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 16px; line-height: 1.25; letter-spacing: -.01em; color: var(--ink); }
  .card p { font-size: 14px; color: var(--ink-muted); line-height: 1.55; }
  .card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: 16px; border-top: 1px solid var(--border); gap: 12px; }
  .tools { display: flex; gap: 6px; flex-wrap: wrap; }
  .tool-tag { font-size: 11px; font-weight: 500; color: var(--ink-muted); background: var(--bg); border: 1px solid var(--border); border-radius: 5px; padding: 3px 8px; }
  .time-saved { font-size: 12px; font-weight: 500; color: #2B6E4A; background: #E8F5EE; border: 1px solid #B8DECA; border-radius: 20px; padding: 4px 12px; white-space: nowrap; flex-shrink: 0; }
  .card.hidden { display: none; }
  .empty-state { grid-column: 1/-1; text-align: center; padding: 60px 20px; color: var(--ink-faint); font-size: 15px; display: none; }

  /* ── GRID CTA ── */
  .cta-section { background: var(--ink); border-radius: 20px; padding: 56px 40px; text-align: center; margin-top: 64px; }
  .cta-section h2 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 32px; color: #fff; letter-spacing: -.02em; margin-bottom: 14px; }
  .cta-section p { color: #A8A59F; font-size: 16px; max-width: 440px; margin: 0 auto 32px; }
  .cta-btn { display: inline-block; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500; color: #fff; background: var(--green); border: none; border-radius: 10px; padding: 14px 32px; cursor: pointer; text-decoration: none; transition: opacity .15s, transform .15s; }
  .cta-btn:hover { opacity: .9; transform: translateY(-1px); }

  /* ── DETAIL VIEW ── */
  #detailView { display: none; animation: fadeUp .3s ease both; }

  .detail-nav { background: var(--ink); border-bottom: 1px solid rgba(255,255,255,.08); }
  .detail-nav-inner { max-width: 1160px; margin: 0 auto; padding: 0 2rem; display: flex; align-items: center; height: 52px; }
  .back-btn { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 500; color: #A8A59F; background: none; border: none; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: color .15s; padding: 0; }
  .back-btn:hover { color: #fff; }
  .back-btn svg { width: 16px; height: 16px; }
  .breadcrumb-sep { color: rgba(255,255,255,.2); margin: 0 10px; font-size: 13px; }
  .breadcrumb-current { font-size: 14px; color: rgba(255,255,255,.5); }

  .detail-hero { background: var(--ink); padding: 48px 2rem 56px; }
  .detail-hero-inner { max-width: 1160px; margin: 0 auto; }
  .detail-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 500; letter-spacing: .08em; text-transform: uppercase; border-radius: 4px; padding: 4px 12px; margin-bottom: 20px; }
  .detail-h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: clamp(28px,4vw,46px); color: #fff; letter-spacing: -.025em; line-height: 1.08; max-width: 720px; margin-bottom: 16px; }
  .detail-subtitle { font-size: 17px; color: #A8A59F; max-width: 560px; line-height: 1.65; margin-bottom: 28px; }
  .detail-meta { display: flex; gap: 12px; flex-wrap: wrap; }

  .detail-body { max-width: 1160px; margin: 0 auto; padding: 56px 2rem 80px; display: grid; grid-template-columns: 460px 1fr; gap: 64px; align-items: start; }

  /* ── FLOWCHART ── */
  .flowchart-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 18px; padding: 32px 28px; position: sticky; top: 84px; }
  .flowchart-label { font-size: 11px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 24px; }
  .flowchart { display: flex; flex-direction: column; align-items: stretch; }
  .fc-step { border-radius: 10px; padding: 13px 18px; font-size: 13px; line-height: 1.45; font-weight: 400; }
  .fc-trigger { background: var(--fc-color); color: #fff; text-align: center; border-radius: 30px; padding: 11px 20px; font-weight: 500; font-size: 13px; }
  .fc-action { background: var(--surface); border: 1px solid var(--border); border-left: 3px solid var(--fc-color); color: var(--ink); }
  .fc-wait { background: var(--bg); border: 1px dashed var(--border); color: var(--ink-muted); text-align: center; font-size: 12px; }
  .fc-decision { background: var(--fc-bg); border: 1.5px solid var(--fc-color); color: var(--ink); text-align: center; font-weight: 500; }
  .fc-result { background: var(--ink); color: #fff; text-align: center; border-radius: 30px; padding: 11px 20px; font-weight: 500; font-size: 13px; }
  .fc-connector { display: flex; flex-direction: column; align-items: center; padding: 3px 0; }
  .fc-line { width: 1.5px; height: 16px; background: var(--border); }
  .fc-arrowhead { width: 0; height: 0; border-left: 4px solid transparent; border-right: 4px solid transparent; border-top: 6px solid var(--border); }
  .fc-branches { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .fc-branch { border-radius: 8px; padding: 9px 12px; font-size: 12px; font-weight: 500; text-align: center; line-height: 1.35; }
  .fc-branch-yes { background: #E8F5EE; color: #1A5C35; border: 1px solid #B8DECA; }
  .fc-branch-no { background: var(--bg); color: var(--ink-muted); border: 1px solid var(--border); }
  .fc-branch-label { font-size: 10px; font-weight: 500; letter-spacing: .06em; text-transform: uppercase; opacity: .65; margin-bottom: 3px; }

  /* ── DETAIL CONTENT ── */
  .detail-content {}
  .section-label { font-size: 11px; font-weight: 500; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: 14px; }
  .detail-benefits { font-size: 16px; color: var(--ink-muted); line-height: 1.8; margin-bottom: 40px; }
  .detail-tools { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 36px; }
  .detail-tool-tag { font-size: 13px; font-weight: 500; color: var(--ink-muted); background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 6px 14px; }
  .detail-time { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 500; color: #1A5C35; background: #E8F5EE; border: 1px solid #B8DECA; border-radius: 20px; padding: 6px 16px; margin-bottom: 40px; }
  .detail-cta { display: inline-flex; align-items: center; gap: 10px; font-family: 'DM Sans', sans-serif; font-size: 15px; font-weight: 500; color: #fff; background: var(--green); border: none; border-radius: 10px; padding: 14px 28px; cursor: pointer; text-decoration: none; transition: opacity .15s, transform .15s; }
  .detail-cta:hover { opacity: .9; transform: translateY(-1px); }

  /* ── ANIMATIONS ── */
  @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .detail-body { grid-template-columns: 1fr; gap: 40px; }
    .flowchart-wrap { position: static; }
    main { padding: 32px 1.25rem 60px; }
    .hero { padding: 48px 1.25rem 56px; }
    .detail-hero { padding: 36px 1.25rem 44px; }
    .detail-body { padding: 36px 1.25rem 60px; }
    .cta-section { padding: 40px 24px; }
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
